{
  "expo": {
    "name": "FoodNova Dispatch",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "foodnovadispatch",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.riderofferflow.mpig0l",
      "config": {
        "googleMapsApiKey": "AIzaSyDgsBi_YK8BZeIbQsaClGXdqVaGr6Q9NQk"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Share your live location for delivery tracking",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Track deliveries in the background while on the road",
        "NSCameraUsageDescription": "Take selfies and delivery proof photos",
        "NSPhotoLibraryUsageDescription": "Upload verification documents from your gallery"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#00C261"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.foodnova.dispatch",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDgsBi_YK8BZeIbQsaClGXdqVaGr6Q9NQk"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00C261"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Track deliveries while you are on the road"
        }
      ],
      "expo-notifications",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
