# FoodNova Backend Production Environment Contract
# Do not place real secrets in this file. Configure real values in Render.

###############################################################################
# Critical
###############################################################################

# ENVIRONMENT
# Purpose: Selects startup safety behavior and diagnostic exposure.
# Required: yes
# Default behavior: development
# Failure if absent: production safeguards are not enabled.
# Render manual configuration: yes
ENVIRONMENT=production

# DATABASE_URL
# Purpose: PostgreSQL database connection URL.
# Required: yes
# Default behavior: falls back to local SQLite, which is not production-safe.
# Failure if absent: production startup fails.
# Render manual configuration: yes
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# JWT_SECRET
# Purpose: Signs customer, admin, and dispatch JWTs.
# Required: yes
# Default behavior: development secret in non-production only.
# Failure if absent: production startup fails.
# Render manual configuration: yes
JWT_SECRET=

# FIREBASE_SERVICE_ACCOUNT_JSON
# Purpose: Preferred Firebase Admin SDK credentials for FCM push.
# Required: yes, unless FIREBASE_SERVICE_ACCOUNT_PATH is configured.
# Default behavior: push notifications fall back to legacy FCM_SERVER_KEY if set, otherwise fail.
# Failure if absent: rider/customer/admin push notifications may not send.
# Render manual configuration: yes
FIREBASE_SERVICE_ACCOUNT_JSON=

# FIREBASE_SERVICE_ACCOUNT_PATH
# Purpose: Alternative Firebase service account JSON file path.
# Required: yes, unless FIREBASE_SERVICE_ACCOUNT_JSON is configured.
# Default behavior: unused when JSON env is present.
# Failure if absent: push notifications may not send.
# Render manual configuration: only if using a private file path.
FIREBASE_SERVICE_ACCOUNT_PATH=

# NINBVNPORTAL_API_KEY
# Purpose: Authenticates NINBVNPortal identity verification requests.
# Required: yes for live rider NIN verification.
# Default behavior: provider is marked unhealthy and NIN verification is disabled.
# Failure if absent: rider NIN verification falls back to unavailable/manual review behavior.
# Render manual configuration: yes
NINBVNPORTAL_API_KEY=

# CLOUDINARY_CLOUD_NAME
# Purpose: Cloudinary account name for durable media uploads.
# Required: yes for production uploads.
# Default behavior: local upload fallback.
# Failure if absent: uploads may not persist across Render instances/redeploys.
# Render manual configuration: yes
CLOUDINARY_CLOUD_NAME=

# CLOUDINARY_API_KEY
# Purpose: Cloudinary API key.
# Required: yes for production uploads.
# Default behavior: local upload fallback.
# Failure if absent: uploads may not persist across Render instances/redeploys.
# Render manual configuration: yes
CLOUDINARY_API_KEY=

# CLOUDINARY_API_SECRET
# Purpose: Cloudinary API secret.
# Required: yes for production uploads.
# Default behavior: local upload fallback.
# Failure if absent: uploads may not persist across Render instances/redeploys.
# Render manual configuration: yes
CLOUDINARY_API_SECRET=

###############################################################################
# Routing and CORS
###############################################################################

# FRONTEND_URL
# Purpose: Canonical customer/admin frontend URL for links and CORS.
# Required: recommended
# Default behavior: backend built-in FoodNova origins remain allowed.
# Failure if absent: custom frontend origin may be blocked or generated links may use defaults.
# Render manual configuration: yes
FRONTEND_URL=https://foodnova.com.ng

# FRONTEND_ORIGIN
# Purpose: Additional frontend origin for CORS.
# Required: optional
# Default behavior: omitted.
# Failure if absent: that origin is not added to allowlist.
# Render manual configuration: yes if admin/customer frontend uses a separate origin.
FRONTEND_ORIGIN=

# CORS_ORIGINS
# Purpose: Comma-separated additional allowed origins.
# Required: optional
# Default behavior: built-in allowed origins only.
# Failure if absent: unlisted origins are blocked by CORS.
# Render manual configuration: yes if needed.
CORS_ORIGINS=https://foodnova.com.ng,https://www.foodnova.com.ng

###############################################################################
# Google Maps
###############################################################################

# GOOGLE_DIRECTIONS_API_KEY
# Purpose: Preferred key for Directions route geometry, ETA, and distance.
# Required: recommended for production tracking.
# Default behavior: route generation may fall back to other Google keys or direct-line logic.
# Failure if absent: maps may show markers without road-following route data.
# Render manual configuration: yes
GOOGLE_DIRECTIONS_API_KEY=

# GOOGLE_MAPS_API_KEY
# Purpose: Fallback Google key for route/tracking helpers.
# Required: recommended if GOOGLE_DIRECTIONS_API_KEY is not set.
# Default behavior: route helpers may be unavailable.
# Failure if absent: ETA/route quality may degrade.
# Render manual configuration: yes
GOOGLE_MAPS_API_KEY=

# FOODNOVA_PICKUP_LATITUDE
# Purpose: FoodNova pickup/warehouse latitude.
# Required: recommended for dispatch matching and route staging.
# Default behavior: operational zone defaults may be used.
# Failure if absent: pickup route/distance calculations may be less accurate.
# Render manual configuration: yes
FOODNOVA_PICKUP_LATITUDE=

# FOODNOVA_PICKUP_LONGITUDE
# Purpose: FoodNova pickup/warehouse longitude.
# Required: recommended for dispatch matching and route staging.
# Default behavior: operational zone defaults may be used.
# Failure if absent: pickup route/distance calculations may be less accurate.
# Render manual configuration: yes
FOODNOVA_PICKUP_LONGITUDE=

###############################################################################
# Email
###############################################################################

# RESEND_API_KEY
# Purpose: Sends transactional/admin email through Resend.
# Required: recommended
# Default behavior: emails disabled unless EMAIL_ENABLED and key are present.
# Failure if absent: email notifications are skipped.
# Render manual configuration: yes
RESEND_API_KEY=

# EMAIL_ENABLED
# Purpose: Enables outbound email sending.
# Required: optional
# Default behavior: false
# Failure if absent: email notifications are skipped.
# Render manual configuration: yes
EMAIL_ENABLED=true

# EMAIL_FROM
# Purpose: Sender identity for outbound FoodNova email.
# Required: optional
# Default behavior: FoodNova <support@foodnova.com.ng>
# Failure if absent: default sender is used.
# Render manual configuration: yes if sender differs.
EMAIL_FROM=FoodNova <support@foodnova.com.ng>

# ADMIN_NOTIFICATION_EMAIL
# Purpose: Destination for admin operational emails.
# Required: optional
# Default behavior: support@foodnova.com.ng
# Failure if absent: default support email is used.
# Render manual configuration: yes
ADMIN_NOTIFICATION_EMAIL=support@foodnova.com.ng

###############################################################################
# Branding and Invoice
###############################################################################

# FOODNOVA_WEBSITE
# Purpose: Website URL displayed on invoices/settings.
# Required: optional
# Default behavior: https://foodnova.com.ng
# Failure if absent: default website is used.
# Render manual configuration: optional
FOODNOVA_WEBSITE=https://foodnova.com.ng

# FOODNOVA_SUPPORT_EMAIL
# Purpose: Support email displayed on invoices/settings.
# Required: optional
# Default behavior: support@foodnova.com.ng
# Failure if absent: default support email is used.
# Render manual configuration: optional
FOODNOVA_SUPPORT_EMAIL=support@foodnova.com.ng

# FOODNOVA_PHONE
# Purpose: Official FoodNova phone displayed on invoices/settings.
# Required: recommended
# Default behavior: code fallback phone is used.
# Failure if absent: fallback phone may be stale.
# Render manual configuration: yes
FOODNOVA_PHONE=

# FOODNOVA_INSTAGRAM
# Purpose: Instagram handle displayed on invoices/settings.
# Required: optional
# Default behavior: @foodnovalimited
# Failure if absent: default handle is used.
# Render manual configuration: optional
FOODNOVA_INSTAGRAM=@foodnovalimited

# FOODNOVA_TIKTOK
# Purpose: TikTok handle displayed on invoices/settings.
# Required: optional
# Default behavior: @foodnovalimited
# Failure if absent: default handle is used.
# Render manual configuration: optional
FOODNOVA_TIKTOK=@foodnovalimited

# FOODNOVA_TAGLINE
# Purpose: Tagline displayed on invoices/settings.
# Required: optional
# Default behavior: Quality Food, Delivered Fresh
# Failure if absent: default tagline is used.
# Render manual configuration: optional
FOODNOVA_TAGLINE=Quality Food, Delivered Fresh

###############################################################################
# Diagnostics and Optional
###############################################################################

# DISPATCH_TEST_MODE
# Purpose: Allows dispatch testing without geofence/distance restrictions.
# Required: optional
# Default behavior: false
# Failure if absent: production dispatch rules apply.
# Render manual configuration: only for staging or explicit testing.
DISPATCH_TEST_MODE=false

# ALLOW_STARTUP_SCHEMA_MUTATIONS
# Purpose: Allows create_all/compatibility schema mutation during startup.
# Required: optional
# Default behavior: false in staging/production, true in development.
# Failure if absent: staging/production report drift and refuse mutation.
# Render manual configuration: only enable after backup and review.
ALLOW_STARTUP_SCHEMA_MUTATIONS=false

# NINBVNPORTAL_BASE_URL
# Purpose: NINBVNPortal API base URL.
# Required: optional
# Default behavior: https://ninbvnportal.com.ng/api
# Failure if absent: default provider URL is used.
# Render manual configuration: optional
NINBVNPORTAL_BASE_URL=https://ninbvnportal.com.ng/api

# NINBVNPORTAL_TIMEOUT_SECONDS
# Purpose: NIN provider request timeout.
# Required: optional
# Default behavior: bounded timeout in service code.
# Failure if absent: default timeout is used.
# Render manual configuration: optional
NINBVNPORTAL_TIMEOUT_SECONDS=25

# NINBVNPORTAL_DIAGNOSTIC_NIN
# Purpose: Admin-only provider diagnostic test NIN.
# Required: optional
# Default behavior: diagnostic default in code.
# Failure if absent: diagnostic default is used.
# Render manual configuration: staging only; use authorized test data.
NINBVNPORTAL_DIAGNOSTIC_NIN=

# FCM_SERVER_KEY
# Purpose: Legacy FCM fallback server key.
# Required: optional legacy
# Default behavior: unused when Firebase Admin credentials are present.
# Failure if absent: no legacy fallback.
# Render manual configuration: only if Firebase Admin SDK credentials cannot be used.
FCM_SERVER_KEY=
