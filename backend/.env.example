# Backend environment variables
ENVIRONMENT=development
DATABASE_URL=sqlite:///./foodnova.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/foodnova

SECRET_KEY=your-secret-key-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# Upload settings
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIRECTORY=uploads

# Worker KYC / NIN verification
NINBVNPORTAL_BASE_URL=https://ninbvnportal.com.ng/api
NINBVNPORTAL_API_KEY=
NINBVNPORTAL_TIMEOUT_SECONDS=25
# Temporary diagnostics only. Replace with an authorized test NIN before using the admin test button.
NINBVNPORTAL_DIAGNOSTIC_NIN=

# Database
SQLALCHEMY_ECHO=False
ALLOW_STARTUP_SCHEMA_MUTATIONS=True

# Firebase Cloud Messaging
# Preferred: paste the full Firebase service account JSON into FIREBASE_SERVICE_ACCOUNT_JSON
# or set FIREBASE_SERVICE_ACCOUNT_PATH to a private JSON file path on the server.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
# Optional legacy fallback if your Firebase project still supports server keys.
FCM_SERVER_KEY=

# Server-side road routing. Enable Directions API and billing for this key.
# Never use the unrestricted browser or mobile key here.
GOOGLE_DIRECTIONS_API_KEY=

# Dispatch feature configuration
RIDER_EARNINGS_ENABLED=false
DISPATCH_TEST_MODE=false
