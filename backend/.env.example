# Backend environment variables
DATABASE_URL=sqlite:///./foodnova.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/foodnova

SECRET_KEY=your-secret-key-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# Upload settings
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIRECTORY=uploads

# Worker KYC / NIN verification
CHECKMYNINBVN_BASE_URL=https://checkmyninbvn.com.ng/api
CHECKMYNINBVN_API_KEY=your_api_key_here

# Database
SQLALCHEMY_ECHO=False
